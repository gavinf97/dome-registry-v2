{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "mail/templates/**/*.hbs", "watchAssets": true },
      { "include": "../schema/*.json", "outDir": "dist/schema", "watchAssets": false }
    ]
  }
}
