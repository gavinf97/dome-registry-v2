{
  "name": "dome-registry-backend",
  "version": "2.0.0",
  "description": "DOME Registry V2 — NestJS API Gateway",
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs'); const src='../schema'; const dst='schema'; if(fs.existsSync(src) && !fs.existsSync(dst)) fs.cpSync(src, dst, {recursive:true});\"",
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/mongoose": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/throttler": "^6.2.0",
    "@nestjs/config": "^3.2.0",
    "mongoose": "^8.5.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "helmet": "^7.1.0",
    "nanoid": "^3.3.7",
    "uuid": "^10.0.0",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.7.0",
    "nodemailer": "^6.9.0",
    "handlebars": "^4.7.8",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.4.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0"
  }
}
