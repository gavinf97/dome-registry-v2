# ─── DOME Registry V2 — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env to git.

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017/dome-registry-v2

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY=1h

# ─── ORCID OAuth 2.0 ─────────────────────────────────────────────────────────
# Register at https://orcid.org/developer-tools
ORCID_CLIENT_ID=APP-XXXXXXXXXXXXXXXX
ORCID_CLIENT_SECRET=your-orcid-client-secret
# Must match the redirect URI registered in your ORCID app
ORCID_REDIRECT_URI=https://yourdomain.com/auth/orcid/callback

# ─── Frontend URL (used for CORS + ORCID redirect) ───────────────────────────
FRONTEND_URL=http://localhost:4200

# ─── Email / SMTP ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="DOME Registry <noreply@example.com>"

# ─── DOME Copilot / LLM ──────────────────────────────────────────────────────
# LLM_MODE=local  → uses Ollama container (Gemma 4, for dev)
# LLM_MODE=api    → uses LLM_ENDPOINT below (for production)
LLM_MODE=local

# When LLM_MODE=api — point to any OpenAI-compatible endpoint
LLM_ENDPOINT=https://vllm.cloud.ai4eosc.eu
LLM_CHAT=AI4EOSC/mistralai/Mistral-Small-3.1-24B-Instruct-2503
LLM_EMBEDDINGS=AI4EOSC/Qwen/Qwen3-Embedding-4B
OPENAI_API_KEY=sk-your-api-key-here

# When LLM_MODE=local — Ollama model to use
OLLAMA_MODEL=gemma3:4b

# Maximum Copilot calls per ORCID user per day
LLM_DAILY_QUOTA=5

# ─── Backend internal ────────────────────────────────────────────────────────
# URL of the Copilot service (internal Docker network — do not expose publicly)
COPILOT_URL=http://copilot:8000
COPILOT_TIMEOUT_MS=120000

# ─── API throttling ──────────────────────────────────────────────────────────
# Global: max requests per window per IP
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
